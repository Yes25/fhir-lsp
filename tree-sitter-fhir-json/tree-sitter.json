{
  "grammars": [
    {
      "name": "fhir_json",
      "camelcase": "FhirJson",
      "scope": "source.fhir_json",
      "file-types": [
        ".JSON",
        ".json"
      ],
      "injection-regex": "^fhir_json$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "FhirJson grammar for tree-sitter",
    "authors": [
      {
        "name": "Jesse"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-fhir_json"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}